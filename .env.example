# Скопируйте в .env.local и заполните. Секреты в клиент не уходят — публичен
# только NEXT_PUBLIC_*.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ИИ-заполнение
BBD_AI_KEY=
BBD_AI_BASE_URL=https://api.deepseek.com/v1
BBD_AI_MODEL=deepseek-chat

# Web push (VAPID). Сгенерировать: npx web-push generate-vapid-keys
# Публичный ключ клиент получает через /api/config; приватный — только сервер.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Секрет, которым защищён POST/GET /api/push/dispatch (заголовок
# Authorization: Bearer <secret> или x-cron-secret). Vercel Cron добавляет его сам.
CRON_SECRET=
